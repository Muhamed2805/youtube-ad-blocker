{
  "manifest_version": 3,
  "name": "YouTube AdBlock",
  "version": "1.0",
  "description": "Blokira reklame na YouTube-u",
  "permissions": ["declarativeNetRequest", "storage"],
  "host_permissions": ["*://*.youtube.com/*", "*://*.googlevideo.com/*", "*://*.doubleclick.net/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ]
}